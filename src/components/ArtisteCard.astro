---
import PbImage from './PbImage.astro';

const { artiste } = Astro.props;
---

<div class="group flex flex-col">
  <div class="relative aspect-square overflow-hidden bg-vert-300 mb-6 rounded-sm">
    <PbImage 
      record={artiste} 
      fileName={artiste.photo} 
      alt={artiste.nom}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 grayscale hover:grayscale-0"
    />
  </div>
  
  <div class="flex flex-col border-t border-beige-100 pt-4">
    <h2 class="font-display text-4xl text-beige-100 uppercase italic leading-none mb-2">
      {artiste.nom}
    </h2>
    <p class="font-body text-corp-lg text-beige-100 opacity-80 uppercase tracking-widest">
      {artiste.genre || "Performance"}
    </p>
  </div>
</div>