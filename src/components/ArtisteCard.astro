---
import PbImage from './PbImage.astro';
const { artiste } = Astro.props;
---
<div class="group flex flex-col bg-transparent">
  <div class="relative aspect-square overflow-hidden bg-slate-800 mb-6 rounded-lg">
    <PbImage 
      record={artiste} 
      fileName={artiste.photo} 
      alt={artiste.nom} 
      class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"
    />
  </div>
  <div class="border-t border-white/20 pt-4">
    <h2 class="font-display text-4xl text-white uppercase italic leading-none">{artiste.nom}</h2>
    <p class="font-body text-white/70 uppercase mt-2 tracking-widest text-sm">{artiste.genre}</p>
  </div>
</div>