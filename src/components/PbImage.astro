---
const { record, collectionId, id, fileName, alt = "", class: className = "" } = Astro.props;

const finalCollectionId = record?.collectionId || collectionId;
const finalId = record?.id || id;

const url = fileName && finalCollectionId && finalId
  ? `https://echosonore.perruchot.optimiseus.fr/api/files/${finalCollectionId}/${finalId}/${fileName}`
  : '/placeholder.jpg';
---
<img src={url} alt={alt} class={className} loading="lazy" />