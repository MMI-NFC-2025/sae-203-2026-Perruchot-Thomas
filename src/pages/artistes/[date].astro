---
import Layout from '../../layouts/Layout.astro';
// On importe la fonction qui récupère TOUS les artistes (sans filtre de date)
import { getAllArtistes } from '../../../backend/backend.mjs';

export async function getStaticPaths() {
  return [
    { params: { date: '28-octobre' } },
    { params: { date: '29-octobre' } },
    { params: { date: '30-octobre' } },
    { params: { date: '31-octobre' } },
  ];
}

const { date } = Astro.params;

// ÉTAPE DE TEST : On récupère tout le monde pour voir si ça s'affiche
const artistes = await getAllArtistes();

const datesNav = [
    { label: '28 OCT', slug: '28-octobre' },
    { label: '29 OCT', slug: '29-octobre' },
    { label: '30 OCT', slug: '30-octobre' },
    { label: '31 OCT', slug: '31-octobre' },
];
---

<Layout title={`Artistes - ${date.replace('-', ' ')}`}>
  <main class="grille py-20">
    
    <h1 class="col-span-12 font-display text-8xl text-beige-100 mb-12 uppercase italic">
        Artistes
    </h1>

    <div class="col-span-12 flex flex-wrap gap-4 mb-20">
      {datesNav.map((d) => (
        <a 
          href={`/artistes/${d.slug}`}
          class={`px-10 py-3 rounded-full font-body font-bold text-corp-lg transition-all border-2 border-beige-100 
            ${date === d.slug ? 'bg-beige-100 text-vert-500' : 'text-beige-100 hover:bg-beige-100 hover:text-vert-500'}`}
        >
          {d.label}
        </a>
      ))}
    </div>

    <div class="col-span-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      {artistes.length > 0 ? (
        artistes.map((artiste) => (
          <div class="group flex flex-col bg-transparent">
            <div class="relative aspect-square overflow-hidden bg-vert-300 mb-6">
              {artiste.image ? (
                <img 
                  src={`http://127.0.0.1:8090/api/files/${artiste.collectionId}/${artiste.id}/${artiste.image}`} 
                  alt={artiste.nom}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center bg-vert-300 text-beige-100 font-body italic">Photo bientôt disponible</div>
              )}
            </div>
            
            <div class="flex flex-col border-t border-beige-100 pt-4">
              <h3 class="font-display text-4xl text-beige-100 uppercase italic leading-none mb-2">
                {artiste.nom}
              </h3>
              <p class="font-body text-corp-lg text-beige-100 opacity-80 uppercase tracking-widest">
                {artiste.genre || "Performance"}
              </p>
            </div>
          </div>
        ))
      ) : (
        <div class="col-span-12 py-20 text-center border-2 border-dashed border-beige-100 rounded-lg">
            <p class="font-body text-beige-100 text-xl italic">
                Aucun artiste n'a été trouvé pour le {date.replace('-', ' ')}.
            </p>
        </div>
      )}
    </div>

  </main>
</Layout>