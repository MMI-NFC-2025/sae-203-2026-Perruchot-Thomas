---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import ArtisteCard from '../../components/ArtisteCard.astro';
import { getArtistesByDate } from '../../../backend/backend.mjs';

export async function getStaticPaths() {
  return [
    { params: { date: '28-octobre' }, props: { pbDate: '2026-10-28' } },
    { params: { date: '29-octobre' }, props: { pbDate: '2026-10-29' } },
    { params: { date: '30-octobre' }, props: { pbDate: '2026-10-30' } },
    { params: { date: '31-octobre' }, props: { pbDate: '2026-10-31' } },
  ];
}

const { date } = Astro.params;
const { pbDate } = Astro.props;
const artistes = await getArtistesByDate(pbDate);

const nav = [
    { day: '28 octobre', year: '2026', slug: '28-octobre' },
    { day: '29 octobre', year: '2026', slug: '29-octobre' },
    { day: '30 octobre', year: '2026', slug: '30-octobre' },
    { day: '31 octobre', year: '2026', slug: '31-octobre' },
];
---

<Layout title={`Programmation - ${date}`}>
  <main>
    <div class="bg-beige-100 py-16 mb-12">
        <div class="grille">
            <div class="col-span-12">
                <h1 class="text-vert-500 font-display text-[40px] uppercase tracking-wider mb-2">Artistes</h1>
                <p class="font-body text-vert-500 text-corp-lg italic">Découvrez les artistes présents à notre événement !</p>
            </div>
        </div>
    </div>

    <div class="grille gap-y-16">
        <div class="col-span-12">
            <h2 class="text-beige-100 font-display text-[32px] uppercase mb-10 text-center">Dates</h2>
            
            <div class="flex items-center justify-center w-full max-w-6xl mx-auto px-10">
                <div class="flex flex-wrap justify-center gap-12">
                  {nav.map((item) => (
                    <a href={`/artistes/${item.slug}`} 
                       class={`px-8 py-4 rounded-2xl border-2 border-beige-100 font-bold transition-all text-center leading-tight min-w-[180px] shadow-lg hover:scale-105 active:scale-95
                       ${date === item.slug 
                        ? 'bg-vert-500 text-beige-100' 
                        : 'bg-beige-100 text-vert-500 hover:bg-vert-500 hover:text-beige-100'}`}>
                      {item.day} <br /> <span class="text-sm opacity-80">{item.year}</span>
                    </a>
                  ))}
                </div>
            </div>
        </div>

        <div class="col-span-12 max-w-2xl mx-auto w-full mb-10">
            <h2 class="text-beige-100 font-display text-[32px] uppercase mb-6 text-center">Rechercher un artiste</h2>
            <div class="relative px-4">
                <input 
                    type="text" 
                    id="search-input"
                    placeholder="nom ou style" 
                    class="w-full bg-beige-100 text-vert-500 placeholder:text-vert-500/60 py-4 px-6 rounded-2xl font-body focus:outline-none focus:ring-2 focus:ring-vert-500 shadow-xl"
                />
            </div>
        </div>

        <div id="artistes-grid" class="col-span-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-16 mb-24 px-4">
          {artistes.map((a) => (
              <div class="artiste-card-container transition-all duration-300" 
                   data-nom={a.nom.toLowerCase()} 
                   data-genre={a.genre.toLowerCase()}>
                <ArtisteCard artiste={a} />
              </div>
          ))}
          
          <div id="no-results" class="col-span-full py-20 text-center border-2 border-dashed border-beige-100/20 rounded-xl hidden">
            <p class="text-beige-100/50 italic text-xl font-body">Aucun artiste ou style ne correspond à votre recherche.</p>
          </div>
        </div>
    </div>
  </main>
</Layout>

<script>
  // Script de filtrage Nom et Genre
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const cards = document.querySelectorAll('.artiste-card-container');
  const noResultsMessage = document.getElementById('no-results');

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase().trim();
    let visibleCount = 0;

    cards.forEach((card) => {
      const nom = (card as HTMLElement).dataset.nom || '';
      const genre = (card as HTMLElement).dataset.genre || '';

      if (query === "" || nom.includes(query) || genre.includes(query)) {
        (card as HTMLElement).style.display = 'block';
        visibleCount++;
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });

    if (noResultsMessage) {
      if (visibleCount === 0) {
        noResultsMessage.classList.remove('hidden');
      } else {
        noResultsMessage.classList.add('hidden');
      }
    }
  });
</script>