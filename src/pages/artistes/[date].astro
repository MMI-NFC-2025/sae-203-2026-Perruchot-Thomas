---
import Layout from '../../layouts/Layout.astro';
import ArtisteCard from '../../components/ArtisteCard.astro';
import { getArtistesByDate } from '../../../backend/backend.mjs';

export async function getStaticPaths() {
  return [
    { params: { date: '28-octobre' }, props: { pbDate: '2026-10-28' } },
    { params: { date: '29-octobre' }, props: { pbDate: '2026-10-29' } },
    { params: { date: '30-octobre' }, props: { pbDate: '2026-10-30' } },
    { params: { date: '31-octobre' }, props: { pbDate: '2026-10-31' } },
  ];
}

const { date } = Astro.params;
const { pbDate } = Astro.props;

// Appel de la fonction corrigée
const artistes = await getArtistesByDate(pbDate);

const nav = [
    { label: '28 OCT', slug: '28-octobre' },
    { label: '29 OCT', slug: '29-octobre' },
    { label: '30 OCT', slug: '30-octobre' },
    { label: '31 OCT', slug: '31-octobre' },
];
---

<Layout title={`Programmation - ${date}`}>
  <main class="max-w-7xl mx-auto px-6 py-24">
    <h1 class="font-display text-8xl text-white mb-16 uppercase italic">Artistes</h1>
    
    <div class="flex flex-wrap gap-4 mb-20">
      {nav.map((item) => (
        <a href={`/artistes/${item.slug}`} 
           class={`px-10 py-3 rounded-full border-2 border-white font-bold transition-all
           ${date === item.slug ? 'bg-white text-black' : 'text-white hover:bg-white hover:text-black'}`}>
          {item.label}
        </a>
      ))}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-16">
      {artistes.length > 0 ? (
        artistes.map((a) => <ArtisteCard artiste={a} />)
      ) : (
        <div class="col-span-full py-20 text-center border-2 border-dashed border-white/20 rounded-xl">
            <p class="text-white/50 italic text-xl text-center">
                Aucun artiste programmé pour le {date.replace('-', ' ')}.<br/>
                Vérifie l'année (2026) dans PocketBase.
            </p>
        </div>
      )}
    </div>
  </main>
</Layout>