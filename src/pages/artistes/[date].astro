---
import Layout from '../../layouts/Layout.astro';
import ArtisteCard from '../../components/ArtisteCard.astro';
import { getArtistesByDateProgrammation } from '../../../backend/backend.mjs';

export async function getStaticPaths() {
  return [
    { params: { date: '28-octobre' }, props: { pbDate: '2026-10-28' } },
    { params: { date: '29-octobre' }, props: { pbDate: '2026-10-29' } },
    { params: { date: '30-octobre' }, props: { pbDate: '2026-10-30' } },
    { params: { date: '31-octobre' }, props: { pbDate: '2026-10-31' } },
  ];
}

const { date } = Astro.params;
const { pbDate } = Astro.props;

// On récupère les artistes via le backend
const artistes = await getArtistesByDateProgrammation(pbDate);

const navigationDates = [
    { label: '28 OCT', slug: '28-octobre' },
    { label: '29 OCT', slug: '29-octobre' },
    { label: '30 OCT', slug: '30-octobre' },
    { label: '31 OCT', slug: '31-octobre' },
];
---

<Layout title={`Artistes - ${date}`}>
  <main class="grille py-20">
    
    <h1 class="col-span-12 font-display text-8xl text-beige-100 mb-12 uppercase italic">
        Artistes
    </h1>

    <div class="col-span-12 flex flex-wrap gap-4 mb-20">
      {navigationDates.map((d) => (
        <a 
          href={`/artistes/${d.slug}`}
          class={`px-10 py-3 rounded-full font-body font-bold border-2 border-beige-100 transition-all
            ${date === d.slug ? 'bg-beige-100 text-vert-500' : 'text-beige-100 hover:bg-beige-100 hover:text-vert-500'}`}
        >
          {d.label}
        </a>
      ))}
    </div>

    <div class="col-span-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      {artistes.length > 0 ? (
        artistes.map((artiste) => (
          <ArtisteCard artiste={artiste} />
        ))
      ) : (
        <p class="col-span-12 text-beige-100 italic opacity-60 py-20 text-center border-2 border-dashed border-beige-100">
            Aucun artiste trouvé pour cette date. (Vérifiez les API Rules de PocketBase)
        </p>
      )}
    </div>
  </main>
</Layout>