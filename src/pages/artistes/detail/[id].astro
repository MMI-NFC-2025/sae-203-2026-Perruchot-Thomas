---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import PbImage from '../../../components/PbImage.astro';
import { getArtisteById } from '../../../../backend/backend.mjs';

const { id } = Astro.params;
const artiste = await getArtisteById(id);

if (!artiste) { return Astro.redirect('/404'); }

let datePassage = "Date à venir";
if (artiste.date) {
    const dateObj = new Date(artiste.date);
    datePassage = dateObj.toLocaleDateString('fr-FR', {
        day: 'numeric',
        month: 'long',
        year: 'numeric'
    });
}

const biographie = artiste.resume || "Aucun résumé disponible pour le moment.";
const galerie = artiste.galerie || [];
---

<Layout title={artiste.nom}>
  <main class="grille py-20 gap-y-12">
    
    <div class="col-span-12 flex flex-col gap-2">
      <h1 class="font-display text-6xl text-beige-100 uppercase leading-tight tracking-wider ">
        {artiste.nom}
      </h1>
      <p class="font-display text-6xl text-beige-100 uppercase leading-tight tracking-wider ">
        {datePassage}
      </p>
    </div>

    <div class="col-span-12 lg:col-start-2 lg:col-span-10 bg-beige-100 p-3 rounded-[24px] overflow-hidden shadow-xl">
      <div class="relative aspect-[16/9] overflow-hidden rounded-[16px]">
        <PbImage record={artiste} fileName={artiste.photo} class="w-full h-full object-cover" />
      </div>
    </div>

    <div class="col-span-12 lg:col-start-2">
        <p class="font-body font-semibold text-beige-100 uppercase tracking-widest text-lg">
            {artiste.genre}
        </p>
    </div>

    <section class="col-span-12 lg:col-start-2 lg:col-span-8 mt-4">
      <h2 class="font-display text-6xl text-beige-100 uppercase mb-6 ">
        RÉSUMÉ DE L’ARTISTE
      </h2>
      <div class="font-body text-beige-100 text-lg leading-relaxed opacity-90 border-l-2 border-beige-100 pl-6 whitespace-pre-wrap">
        {biographie}
      </div>
    </section>

    {galerie.length > 0 && (
      <section class="col-span-12 flex flex-col items-center mt-12">
        <h2 class="font-display text-4xl text-beige-100 uppercase mb-8">Galerie</h2>
        
        <div class="relative flex items-center justify-center w-full max-w-4xl px-24">
          
          <button id="prev" class="absolute left-0 w-16 h-16 bg-beige-100 rounded-full flex items-center justify-center shadow-lg hover:scale-110 transition active:scale-95 z-10">
              <span class="w-8 h-8 bg-vert-500" style="mask: url('/arrow-left.svg') no-repeat center / contain; -webkit-mask: url('/arrow-left.svg') no-repeat center / contain;"></span>
          </button>

          <div class="bg-beige-100 p-3 rounded-[24px] w-full max-w-md shadow-xl">
            <div id="gallery-container" class="relative aspect-square overflow-hidden rounded-[16px]">
              {galerie.map((img: string, i: number) => (
                <div class={`gallery-item absolute inset-0 transition-opacity duration-700 ease-in-out ${i === 0 ? 'opacity-100' : 'opacity-0'}`}>
                  <PbImage record={artiste} fileName={img} class="w-full h-full object-cover" />
                </div>
              ))}
            </div>
          </div>

          <button id="next" class="absolute right-0 w-16 h-16 bg-beige-100 rounded-full flex items-center justify-center shadow-lg hover:scale-110 transition active:scale-95 z-10">
              <span class="w-8 h-8 bg-vert-500" style="mask: url('/arrow-right.svg') no-repeat center / contain; -webkit-mask: url('/arrow-right.svg') no-repeat center / contain;"></span>
          </button>

        </div>
      </section>
    )}

    <div class="col-span-12 flex justify-center mt-12">
        <button 
          onclick="history.back()" 
          class="bg-beige-100 text-vert-500 font-body font-bold uppercase px-10 py-4 rounded-xl hover:bg-white transition-all shadow-md"
        >
          Revenir aux artistes
        </button>
    </div>
  </main>
</Layout>

<script>
  const items = document.querySelectorAll('.gallery-item');
  let cur = 0;
  
  if (items.length > 0) {
    const next = document.getElementById('next');
    const prev = document.getElementById('prev');

    next?.addEventListener('click', () => {
      items[cur].classList.replace('opacity-100', 'opacity-0');
      cur = (cur + 1) % items.length;
      items[cur].classList.replace('opacity-0', 'opacity-100');
    });

    prev?.addEventListener('click', () => {
      items[cur].classList.replace('opacity-100', 'opacity-0');
      cur = (cur - 1 + items.length) % items.length;
      items[cur].classList.replace('opacity-0', 'opacity-100');
    });
  }
</script>