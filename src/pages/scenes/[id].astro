---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import PbImage from '../../components/PbImage.astro';
import { getAllScenes, getProgrammationByScene } from '../../../backend/backend.mjs';

export async function getStaticPaths() {
    const scenes = await getAllScenes();
    return scenes.map((s) => ({
        params: { id: s.id },
        props: { scene: s },
    }));
}

const { id } = Astro.params;
const { scene } = Astro.props;

const programmation = await getProgrammationByScene(id);

const datesFestival = [
    { label: '28 OCTOBRE 2026', iso: '2026-10-28', slug: '28-octobre' },
    { label: '29 OCTOBRE 2026', iso: '2026-10-29', slug: '29-octobre' },
    { label: '30 OCTOBRE 2026', iso: '2026-10-30', slug: '30-octobre' },
    { label: '31 OCTOBRE 2026', iso: '2026-10-31', slug: '31-octobre' },
];
---

<Layout title={`Scène - ${scene.nom}`}>
  <main class="grille py-20 gap-y-12">
    
    <div class="col-span-12 lg:col-start-4 lg:col-span-6 bg-beige-100 p-3 rounded-[24px] overflow-hidden shadow-xl">
      <div class="relative aspect-square overflow-hidden rounded-[16px]">
        <PbImage record={scene} fileName={scene.photo} class="w-full h-full object-cover" />
      </div>
    </div>

    <div class="col-span-12 lg:col-start-2 lg:col-span-10 flex flex-col gap-4 mt-12 lg:mt-0">
      <h1 class="font-display text-[40px] text-beige-100 uppercase tracking-wider">
        {scene.nom}
      </h1>
      <div class="font-body text-beige-100 text-lg leading-relaxed opacity-90 border-l-2 border-beige-100 pl-6">
        {scene.description}
      </div>
    </div>

    <div class="col-span-12 mt-12">
        <h2 class="font-display text-[40px] text-beige-100 uppercase tracking-wider">
            LISTE DES ARTISTES
        </h2>
    </div>

    <div class="col-span-12 flex justify-center mt-8">
        <div class="grid grid-cols-2 md:flex md:flex-wrap justify-center gap-4 md:gap-6 w-full max-w-6xl px-4 md:px-10">
            {datesFestival.map((date, index) => (
                <button 
                    data-date-btn={date.iso}
                    class={`date-tab px-4 py-4 md:px-8 rounded-full font-body font-bold uppercase transition-all shadow-lg active:scale-95 text-xs md:text-base border-2
                    ${index === 0 
                        ? 'bg-beige-100 text-vert-500 border-beige-100' 
                        : 'bg-beige-100/20 text-beige-100 border-transparent'}`}>
                    {date.label}
                </button>
            ))}
        </div>
    </div>

<div class="col-span-12 lg:col-start-3 lg:col-span-8 flex flex-col items-center gap-10">
    {datesFestival.map((date, index) => {
        const jourProg = programmation.find(p => p.date.startsWith(date.iso));
        return (
            <div 
                data-date-content={date.iso}
                class={`date-panel w-full flex flex-col items-center ${index !== 0 ? 'hidden' : ''}`}
            >
                <div class="w-full bg-vert-300 p-12 rounded-[40px] shadow-2xl mt-12 md:mt-0">
                    <div class="flex flex-col items-center gap-6">
                        {jourProg && jourProg.expand?.artiste ? (
                            (jourProg.expand.artiste as any[]).map((art) => (
                                <h2 class="font-display text-5xl md:text-7xl text-beige-100 uppercase text-center leading-tight">
                                    {art.nom}
                                </h2>
                            ))
                        ) : (
                            <p class="font-body text-beige-100/60 text-2xl uppercase italic">Aucun artiste ce jour</p>
                        )}
                    </div>
                </div>

                <a href={`/artistes/${date.slug}`} class="bg-beige-100 text-vert-500 font-body font-bold uppercase px-12 py-5 rounded-full shadow-md active:scale-95 transition-all mt-16 lg:mt-12">
                    Voir tous les artistes
                </a>
            </div>
        )
    })}
</div>

    </main>
</Layout>

<script>
    const buttons = document.querySelectorAll('[data-date-btn]');
    const panels = document.querySelectorAll('[data-date-content]');

    buttons.forEach(btn => {
        btn.addEventListener('click', () => {
            const targetDate = btn.getAttribute('data-date-btn');

            buttons.forEach(b => {
                b.classList.remove('bg-beige-100', 'text-vert-500', 'border-beige-100');
                b.classList.add('bg-beige-100/20', 'text-beige-100', 'border-transparent');
            });
            
            btn.classList.add('bg-beige-100', 'text-vert-500', 'border-beige-100');
            btn.classList.remove('bg-beige-100/20', 'text-beige-100', 'border-transparent');

            panels.forEach(panel => {
                if (panel.getAttribute('data-date-content') === targetDate) {
                    panel.classList.remove('hidden');
                } else {
                    panel.classList.add('hidden');
                }
            });
        });
    });
</script>